@{
}
@model IEnumerable<EventEas3.Models._Venue>

@{
    ViewData["Title"] = "Venues";
}

<div class="d-flex justify-content-between align-items-center my-4">
    <h2>Venues</h2>
    <a asp-action="Create" class="btn btn-primary">Add New Venue</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Location</th>
            <th>Address</th>
            <th>Image URL</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.vName</td>
                <td>@item.vLocation</td>
                <td>@item.vAddress</td>
                <td>@(string.IsNullOrEmpty(item.vImage) ? "No Image Provided" : item.vImage)</td>
                <td class="text-center">
                    <a asp-action="Delete" asp-route-id="@item.VenueID" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>