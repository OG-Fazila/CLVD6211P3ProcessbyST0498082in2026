@{
}
@model EventEas3.Models._Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="row justify-content-center my-4">
    <div class="col-md-6 text-center">
        <h2 class="text-danger">Delete Venue</h2>
        <p class="lead">Are you sure you want to delete this venue?</p>

        <div class="card p-4 my-3 border-danger shadow-sm text-start">
            <h5><strong>Name:</strong> @Model.vName</h5>
            <p class="mb-1"><strong>Location:</strong> @Model.vLocation</p>
            <p class="mb-0"><strong>Address:</strong> @Model.vAddress</p>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="VenueID" />
            <a asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
        </form>
    </div>
</div>
