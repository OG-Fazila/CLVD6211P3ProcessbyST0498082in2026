@{
}
@model EventEas3.Models.Booking

@{
    ViewData["Title"] = "Create Booking";
}

<div class="row justify-content-center">
    <div class="col-md-6 my-4">
        <h2>Create Client Booking Slot</h2>
        <div class="card p-4 shadow-sm">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="bName" class="form-label">Client Name</label>
                    <input asp-for="bName" class="form-control" placeholder="e.g., John Doe" />
                    <span asp-validation-for="bName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="bDate" class="form-label">Date</label>
                    <input asp-for="bDate" type="date" class="form-control" />
                    <span asp-validation-for="bDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="bTime" class="form-label">Time</label>
                    <input asp-for="bTime" type="time" class="form-control" />
                    <span asp-validation-for="bTime" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    <button type="submit" class="btn btn-success">Save Booking</button>
                </div>
            </form>
        </div>
    </div>
</div>