@{
}
@model IEnumerable<EventEas3.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<div class="d-flex justify-content-between align-items-center my-4">
    <h2>Bookings</h2>
    <a asp-action="Create" class="btn btn-primary">Add New Booking</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Client/Booking Name</th>
            <th>Reserved Date</th>
            <th>Reserved Time</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>@item.bName</strong></td>
                <td>@item.bDate.ToString("yyyy-MM-dd")</td>
                <td>@item.bTime.ToString(@"hh\:mm")</td>
            </tr>
        }
    </tbody>
</table>