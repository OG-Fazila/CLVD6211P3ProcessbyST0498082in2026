@{
}
@model IEnumerable<EventEas3.Models.Eventie>

@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center my-4">
    <h2>Events</h2>
    <a asp-action="Create" class="btn btn-primary">Add New Event</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger shadow-sm">
        @TempData["Error"]
    </div>
}

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Date & Time</th>
            <th>Event Type</th>
            <th>Duration (Mins)</th>
            <th>Capacity Limit</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.eDateTime.ToString("g")</td>
                <td><span class="badge bg-secondary p-2 text-uppercase">@item.eType</span></td>
                <td>@item.eDuration min</td>
                <td>@item.eLimit</td>
                <td class="text-center">
                    <a asp-action="Delete" asp-route-id="@item.EventID" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>