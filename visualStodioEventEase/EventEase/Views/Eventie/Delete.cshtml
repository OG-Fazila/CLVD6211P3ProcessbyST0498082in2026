@{
}
@model EventEas3.Models.Eventie

@{
    ViewData["Title"] = "Delete Event";
}

<div class="row justify-content-center my-4">
    <div class="col-md-6 text-center">
        <h2 class="text-danger">Delete Event</h2>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-warning border border-warning shadow-sm my-3 text-start">
                <strong>Notice:</strong> @ViewBag.ErrorMessage
            </div>
        }
        else
        {
            <p class="lead">Are you sure you want to delete this event?</p>
        }

        <div class="card p-4 my-3 text-start shadow-sm border-danger">
            <h5><strong>Type:</strong> @Model.eType</h5>
            <p class="mb-1"><strong>Scheduled:</strong> @Model.eDateTime.ToString("f")</p>
            <p class="mb-0"><strong>Limit:</strong> @Model.eLimit People</p>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="EventID" />
            <a asp-action="Index" class="btn btn-secondary me-2">Cancel</a>

            @if (ViewBag.ErrorMessage == null)
            {
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
            }
            else
            {
                <button type="submit" class="btn btn-danger" disabled>Cannot Delete</button>
            }
        </form>
    </div>
</div>